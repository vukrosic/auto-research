# OS and Python noise
.DS_Store
__pycache__/
*.py[cod]
.venv/
venv/
/.venv-ppt/

# Local control-plane logs
/logs/
/reports/*.jsonl
/reports/*.pptx

# Derived state (regenerated each session)
/state/ACTIVE_RUNS.md
/state/ADJUDICATION_QUEUE.md
/state/FRONTIER.md

# Experiments — runtime data stays local, base structure is tracked per-project
/experiments/*/snapshots/*
!/experiments/*/snapshots/README.md
/experiments/*/base_backup_*/
/experiments/*/base_id.txt
/experiments/*/base/queues/active.txt
/experiments/*/base/records/*
!/experiments/*/base/records/README.md

# Legacy flat experiment paths (remove after full migration)
/experiments/base_id.txt
/experiments/base_backup_*/
/experiments/base/queues/active.txt
/experiments/snapshots/*/code/
/experiments/snapshots/*/gpu
/experiments/snapshots/*/remote_pid
/experiments/snapshots/*/results/nohup.log
/experiments/snapshots/*/results/train.log
/experiments/snapshots/*/results/runtime.json

# Local machine and credential config — NEVER commit
/scripts/gpu_config.sh
.cycle.lock
/goals/*/*.pid
